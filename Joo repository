#include<iostream>
using namespace std;

/************************************* Insertion Sort *********************/

void insertionSort(int array[], int n) {
	for (int i = 1, j; i < n; i++) {
		int temp = array[i];
		for (j = i; j > 0 && temp < array[j - 1]; j--) {
			array[j] = array[j - 1];
		}
		array[j] = temp;
	}
}

/************************************* Selection Sort *********************/

void selectionSort(int array[], int n) {
	for (int i = 0, j, least; i < n-1; i++) {
		for (j = i + 1, least = i; j < n; j++)
			if (array[j] < array[least])
				least = j;
		swap(array[least], array[i]);
	}
}

/************************************* Bubble Sort ***********************/

void bubbleSort(int array[], int n) {
	for (int i = 0; i < n - 1; i++) {
		for (int j = 1; j < n - i; j++)
			if (array[j] < array[j - 1])
				swap(array[j], array[j - 1]);
	}
}

/************************************* Shell Sort ************************/

void shellSort(int array[], int n) {
	for (int gap = n / 2; gap > 0; gap /= 2) {
		for (int i = gap; i < n; i++) {
			int temp = array[i];
			int j = i;
			for (; j >= gap && temp < array[j - gap]; j -= gap) {
				array[j] = array[j - gap];
			}
			array[j] = temp;
		}
	}
}

/************************************* Merge Sort ************************/

void merge(int array[], int left, int middle, int right) {  //for merging the array delivered and sorting the merged arrays
	
	int i, j, k;    //i for left subarray , j for right subarray , k for merged array
	
	int n1 = middle - left + 1;  //size of of left subarray
	int n2 = right - middle; //size of right subarray
	
	int* leftSubArray = new int[n1];
	int* rightSubArray = new int[n2];

	for (i = 0; i < n1; i++) {     //fill in left subarray from original array 
		leftSubArray[i] = array[left + i];  
	}
	for (j = 0; j < n2; j++) {     //fill in right subarray from original barray 
		rightSubArray[j] = array[middle + 1 + j];
	}

	i = j = 0;
	k = left;

	while (i < n1 && j < n2) {     //comparison between two subarrays
		if (leftSubArray[i] <= rightSubArray[j]) {
			array[k] = leftSubArray[i];
			i++;
		}
		else {
			array[k] = rightSubArray[j];
			j++;
		}
		k++;
	}

	//for elements left after comparison for the two subarrays if there is any
	while (i < n1) {
		array[k] = leftSubArray[i];
		i++;
		k++;
	}
	while (j < n2) {
		array[k] = rightSubArray[j];
		j++;
		k++;
	}
}

void mergeSort(int array[], int left, int right) {
	if (left < right) {
		int middle = left + (right - left) / 2;
		mergeSort(array, left, middle);
		mergeSort(array, middle + 1, right);
		merge(array, left, middle, right);
	}
}

/************************************* Quick Sort ************************/

int partition(int array[], int left, int right) {
	int pivot = array[left];
	int i = left;
	int j = right;
	while (i < j) {
		do {
			i++;
		} while (array[i] <= pivot);
		do {
			j--;
		} while (array[j] > pivot);
		if (i < j) {
			swap(array[i], array[j]);
		}
	}
	swap(array[left], array[j]);
	return j;
}

void quickSort(int array[], int left, int right) {
	if (left < right) {
		int pivot = partition(array, left, right);
		quickSort(array, left, pivot);
		quickSort(array, pivot + 1, right);
	}
} 

